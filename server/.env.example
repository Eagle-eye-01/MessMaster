PORT=5000
# Replace with your MongoDB connection string (e.g. from MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/messmaster?retryWrites=true&w=majority
# Generate secure random strings (e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
CLIENT_URL=http://localhost:5173
BCRYPT_SALT_ROUNDS=12
NODE_ENV=development